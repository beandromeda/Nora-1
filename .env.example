# Copy this file to .env.local (which is gitignored) and fill in real values.
# These are exposed to the browser by Vite — only put public values here.
# Real secrets (database password, service-role key) must NEVER go in VITE_* vars.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
